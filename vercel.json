{
  "rewrites": [
    {
      "source": "/api/compile/coliru",
      "destination": "https://coliru.stacked-crooked.com/compile"
    },
    {
      "source": "/api/compile/godbolt/:compiler",
      "destination": "https://godbolt.org/api/compiler/:compiler/compile"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
